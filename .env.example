# Copy to .env and fill in real values. Never commit .env.

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret
TARGET_REPO=<YOUR_ORG>/<YOUR_REPO>
TARGET_BRANCH=main

# ── LLM (self-hosted, no external tokens needed) ─────────────
# Provider: "litellm" (recommended) | "ollama" | "vllm" | "anthropic" | "openai"
AI_PROVIDER=litellm
AI_MODEL=coding-model
AI_REVIEW_MODEL=review-model

# LiteLLM gateway — routes to Ollama/vLLM backends.
# In-cluster: http://litellm.ai-models.svc.cluster.local:4000/v1
# Local dev:  http://localhost:4000/v1  (port-forward: kubectl -n ai-models port-forward svc/litellm 4000:4000)
AI_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=sk-internal-agents-local

# Direct Ollama (when AI_PROVIDER=ollama, bypasses LiteLLM)
# In-cluster: http://ollama.ai-models.svc.cluster.local:11434/v1
# Local dev:  http://localhost:11434/v1  (port-forward: kubectl -n ai-models port-forward svc/ollama 11434:11434)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── External LLM (optional, leave empty for local-only) ──────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Langfuse (optional observability) ─────────────────────────
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Agent behaviour ──────────────────────────────────────────
CONTEXT_SOURCE=issues
CONTEXT_ISSUE_LABEL=ai-agent
AUTO_ASSIGN_REVIEWER=true
DRY_RUN=false
